{
  "profiles": {
    "openai-default": {
      "provider": "openai_compatible",
      "credentials_ref": "openai-main",
      "base_url": "https://api.openai.com/v1",
      "model": "gpt-4.1-mini",
      "params": {
        "temperature": 0.7,
        "max_tokens": 1024
      }
    },
    "local-openai-compatible": {
      "provider": "openai_compatible",
      "base_url": "http://127.0.0.1:1234/v1",
      "model": "local-model",
      "no_auth": true,
      "params": {
        "temperature": 0.2
      }
    },
    "custom-http-video-job": {
      "provider": "custom_http",
      "credentials_ref": "custom-http-main",
      "params": {
        "method": "POST",
        "url": "/v1/video/jobs",
        "poll_url": "/v1/video/jobs/{job_id}",
        "job_id_path": "id",
        "status_path": "status",
        "success_values": [
          "succeeded",
          "completed"
        ],
        "failure_values": [
          "failed",
          "error"
        ],
        "download_result": true,
        "download_url_path": "result.video_url",
        "output_extension": "mp4"
      }
    }
  }
}
