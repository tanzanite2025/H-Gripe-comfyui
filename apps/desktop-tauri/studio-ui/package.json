{
  "name": "hgripe-studio-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "H-Gripe Studio node-graph editor (React Flow). Renderer-agnostic graph model + DAG runtime; integrates with the H-Gripe broker.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@xyflow/react": "12.3.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@testing-library/react": "16.0.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.3",
    "jsdom": "24.1.3",
    "typescript": "5.6.3",
    "vite": "5.4.21",
    "vitest": "3.2.6"
  }
}
