{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "H-Gripe Desktop",
  "version": "0.1.0",
  "identifier": "com.hgripe.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "H-Gripe Desktop",
        "width": 1180,
        "height": 800,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
